# ============================================================
# Speed-to-Lead .env template
# Copy to .env and fill in. NEVER commit the filled-in file.
# On Render/Railway, enter these in the dashboard instead.
# ============================================================

PORT=3000

# --- Twilio (SMS) ---
# Console: https://console.twilio.com  (Account SID starts with AC)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The purchased local number, E.164 format e.g. +15551234567
TWILIO_FROM_NUMBER=

# --- SMTP (email) ---
# Google Workspace: smtp.gmail.com / 587 / app password
# SendGrid: smtp.sendgrid.net / 587 / user "apikey" / pass = API key
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=

# --- Admin alert targets (the BD reps) ---
# Comma-separate for multiple recipients
ADMIN_EMAIL=
ADMIN_PHONE=

# --- Behavior ---
# Delay before the lead gets their follow-up (180000 ms = 3 minutes)
# Set to 5000 during go-live testing, then back to 180000
FOLLOW_UP_DELAY_MS=180000

# Shared secret for server-to-server intake (Zapier, webhooks).
# Generate one: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# REQUIRED in production. Callers pass it as ?token=... or X-STL-Token header.
INTAKE_TOKEN=
